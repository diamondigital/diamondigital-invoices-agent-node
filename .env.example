# Diamondigital Documents Upload Agent — local dev config
# Copy to .env and fill in values

NODE_ENV=local

# Email (IMAP)
EMAIL_HOST=imap.seznam.cz
EMAIL_PORT=993
EMAIL_SECURE=true
EMAIL_USER=invoices@diamondigital.cz
EMAIL_PASSWORD=<EMAIL_PASSWORD>
# IMAP folders (Seznam has no labels). INBOX = unprocessed queue.
# Uploaded → EMAIL_PROCESSED_LABEL; no accounting doc found → EMAIL_SKIPPED_FOLDER.
EMAIL_PROCESSED_LABEL=TRIVI
EMAIL_SKIPPED_FOLDER=Bez dokladu

# TRIVI API
TRIVI_APP_ID=<TRIVI_APP_ID>
TRIVI_APP_SECRET=<TRIVI_APP_SECRET>
TRIVI_BASE_URL=https://api.trivi.com/v2

# Mistral — classifies each attachment as an accounting document before upload.
# Images go through vision (no OCR); PDFs through OCR + the same cheap model.
# Required. Defaults: model=ministral-8b-latest, upload threshold=0.85.
MISTRAL_API_KEY=<MISTRAL_API_KEY>
# MISTRAL_CLASSIFIER_MODEL=ministral-8b-latest
# MISTRAL_UPLOAD_THRESHOLD=0.85

# Optional: SNS topic ARN (empty = log only)
SNS_TOPIC_ARN=

# Optional: S3 bucket (empty = skip archive)
S3_BUCKET=

# Admin email for alerts
ADMIN_EMAIL=admin@diamondigital.cz
