# Diamondigital Documents Upload Agent — local dev config
# Copy to .env and fill in values

NODE_ENV=local

# Email (IMAP)
EMAIL_HOST=imap.seznam.cz
EMAIL_PORT=993
EMAIL_SECURE=true
EMAIL_USER=invoices@diamondigital.cz
EMAIL_PASSWORD=***

# TRIVI API
TRIVI_APP_ID=***REDACTED-TRIVI-APP-ID***
TRIVI_APP_SECRET=***REDACTED-TRIVI-APP-SECRET***
TRIVI_BASE_URL=https://api.trivi.com/v2
TRIVI_UPLOADED_DOCUMENTS_PATH=/accountingdocuments/uploaded
TRIVI_UPLOAD_FIELD_NAME=file

# Optional legacy invoice-creation settings
TRIVI_BANK_ACCOUNT_ID=0

# Optional legacy Mistral settings (not used by uploaded-documents flow)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Optional: SNS topic ARN (empty = log only)
SNS_TOPIC_ARN=

# Optional: S3 bucket (empty = skip archive)
S3_BUCKET=

# Admin email for alerts
ADMIN_EMAIL=admin@diamondigital.cz
